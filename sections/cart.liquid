{% comment %}
  This section is used in the cart template to render /cart page with an
  overview of the items in customer's cart.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/cart
{% endcomment %}

<!-- =============================================
     CART PAGE
     Shows all items in cart.
     Lets user update quantity or remove items.
     Shows total and checkout button.
     ============================================= -->

<!-- Cart Header -->
<div class="cart-header">
  <div class="container">
    <h1 class="cart-header__title">Your Cart</h1>
    <p class="cart-header__sub">
      {{ cart.item_count }}
      {% if cart.item_count == 1 %}item{% else %}items{% endif %}
      in your cart
    </p>
  </div>
</div>

<section class="section">
  <div class="container">

    {% if cart.item_count > 0 %}

      <div class="cart__inner">

        <!-- LEFT — Cart Items List -->
        <div class="cart__items">

          <!-- Cart Table Header -->
          <div class="cart__table-header">
            <span>Product</span>
            <span>Price</span>
            <span>Quantity</span>
            <span>Total</span>
          </div>

          <!-- Cart Items -->
          <form action="/cart" method="post" id="cartForm">

            {% for item in cart.items %}
              <div class="cart-item" id="cartItem-{{ item.key }}">

                <!-- Product Image -->
                <div class="cart-item__img">
                  <a href="{{ item.url }}">
                    {% if item.image %}
                      <img
                        src="{{ item.image | image_url: width: 200 }}"
                        alt="{{ item.title }}"
                      >
                    {% else %}
                      <div class="cart-item__img-placeholder">💪</div>
                    {% endif %}
                  </a>
                </div>

                <!-- Product Info -->
                <div class="cart-item__info">
                  <a href="{{ item.url }}" class="cart-item__name">
                    {{ item.product_title }}
                  </a>
                  {% if item.variant_title != 'Default Title' %}
                    <p class="cart-item__variant">{{ item.variant_title }}</p>
                  {% endif %}

                  <!-- Remove button — mobile only -->
                  <button
                    type="button"
                    class="cart-item__remove-mobile"
                    onclick="removeItem('{{ item.key }}')"
                  >
                    Remove
                  </button>
                </div>

                <!-- Price -->
                <div class="cart-item__price">
                  {{ item.price | money }}
                </div>

                <!-- Quantity Control -->
                <div class="cart-item__qty">
                  <div class="qty-selector">
                    <button
                      type="button"
                      class="qty-btn"
                      onclick="updateQty('{{ item.key }}', {{ item.quantity | minus: 1 }})"
                    >−</button>
                    <input
                      type="number"
                      name="updates[]"
                      value="{{ item.quantity }}"
                      min="0"
                      max="10"
                      class="qty-input"
                      id="qty-{{ item.key }}"
                      readonly
                    >
                    <button
                      type="button"
                      class="qty-btn"
                      onclick="updateQty('{{ item.key }}', {{ item.quantity | plus: 1 }})"
                    >+</button>
                  </div>
                </div>

                <!-- Line Total -->
                <div class="cart-item__total">
                  {{ item.line_price | money }}
                  <!-- Remove button — desktop -->
                  <button
                    type="button"
                    class="cart-item__remove"
                    onclick="removeItem('{{ item.key }}')"
                    aria-label="Remove item"
                  >
                    ✕
                  </button>
                </div>

              </div>
            {% endfor %}

          </form>

          <!-- Continue Shopping -->
          <div class="cart__continue">
            <a href="/collections/all" class="btn btn--ghost-dark">
              ← Continue Shopping
            </a>
          </div>

        </div>

        <!-- RIGHT — Order Summary -->
        <div class="cart__summary">

          <div class="cart__summary-box">
            <h3 class="cart__summary-title">Order Summary</h3>

            <!-- Price Breakdown -->
            <div class="cart__summary-rows">

              <div class="cart__summary-row">
                <span>Subtotal</span>
                <span>{{ cart.total_price | money }}</span>
              </div>

              <div class="cart__summary-row">
                <span>Shipping</span>
                <span class="text-orange">
                  {% if cart.total_price >= 99900 %}
                    FREE
                  {% else %}
                    Calculated at checkout
                  {% endif %}
                </span>
              </div>

              {% if cart.total_price < 99900 %}
                <!-- Free shipping progress -->
                <div class="cart__free-shipping">
                  <p class="cart__free-shipping-text">
                    Add
                    <strong>{{ 99900 | minus: cart.total_price | money }}</strong>
                    more for free shipping!
                  </p>
                  <div class="cart__free-shipping-bar">
                    <div
                      class="cart__free-shipping-fill"
                      style="width: {{ cart.total_price | times: 100 | divided_by: 99900 }}%"
                    ></div>
                  </div>
                </div>
              {% endif %}

            </div>

            <!-- Total -->
            <div class="cart__summary-total">
              <span>Total</span>
              <span>{{ cart.total_price | money }}</span>
            </div>

            <!-- Checkout Button -->
            <a href="/checkout" class="btn btn--primary btn--full btn--lg cart__checkout-btn">
              Proceed to Checkout →
            </a>

            <!-- Payment Icons -->
            <div class="cart__payment-icons">
              <span>💳</span>
              <span>Secure checkout</span>
            </div>

            <!-- AI Coach nudge -->
            <a href="/pages/ai-coach" class="cart__ai-nudge">
              🤖 Not sure what else you need? Ask our AI Coach
            </a>

          </div>

          <!-- Trust Items -->
          <div class="cart__trust">
            <div class="cart__trust-item">
              <span>🛡️</span>
              <p>100% Authentic products</p>
            </div>
            <div class="cart__trust-item">
              <span>🚚</span>
              <p>Free shipping above ₹999</p>
            </div>
            <div class="cart__trust-item">
              <span>↩️</span>
              <p>Easy 7-day returns</p>
            </div>
          </div>

        </div>

      </div>

    {% else %}

      <!-- Empty Cart State -->
      <div class="cart__empty">
        <div class="cart__empty-icon">🛒</div>
        <h2>Your cart is empty</h2>
        <p>Looks like you haven't added anything yet. Let's fix that.</p>
        <div class="cart__empty-btns">
          <a href="/collections/all" class="btn btn--primary btn--lg">
            Shop Supplements
          </a>
          <a href="/pages/ai-coach" class="btn btn--ghost-dark btn--lg">
            🤖 Get AI Recommendation
          </a>
        </div>
      </div>

    {% endif %}

  </div>
</section>

<style>
/* Cart Header */
.cart-header {
  background: var(--color-black);
  padding: 40px 0 28px;
  border-bottom: 3px solid var(--color-orange);
}

.cart-header__title {
  color: var(--color-white);
  margin-bottom: 8px;
}

.cart-header__sub {
  color: #888888;
  font-size: 14px;
  margin: 0;
}

/* Cart Layout */
.cart__inner {
  display: grid;
  grid-template-columns: 1fr 360px;
  gap: 40px;
  align-items: start;
}

/* Table Header */
.cart__table-header {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 16px;
  padding: 12px 0;
  border-bottom: 2px solid var(--color-black);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--color-text-muted);
  margin-bottom: 8px;
}

/* Cart Item */
.cart-item {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 16px;
  align-items: center;
  padding: 20px 0;
  border-bottom: 1px solid var(--color-border);
}

.cart-item__img {
  display: flex;
  align-items: center;
  gap: 16px;
  grid-column: 1;
}

.cart-item__img img {
  width: 80px;
  height: 80px;
  object-fit: cover;
  border-radius: var(--radius-sm);
  border: 1px solid var(--color-border);
  flex-shrink: 0;
}

.cart-item__img-placeholder {
  width: 80px;
  height: 80px;
  background: var(--color-bg-light);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  flex-shrink: 0;
}

.cart-item__info {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.cart-item__name {
  font-size: 14px;
  font-weight: 600;
  color: var(--color-black);
  line-height: 1.3;
  transition: color 0.2s;
}

.cart-item__name:hover {
  color: var(--color-orange);
}

.cart-item__variant {
  font-size: 12px;
  color: var(--color-text-muted);
  margin: 0;
}

.cart-item__remove-mobile {
  display: none;
  font-size: 12px;
  color: #E24B4A;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  text-align: left;
  margin-top: 4px;
}

.cart-item__price {
  font-size: 15px;
  font-weight: 500;
  color: var(--color-black);
}

.cart-item__total {
  font-size: 15px;
  font-weight: 600;
  color: var(--color-black);
  display: flex;
  align-items: center;
  gap: 12px;
}

.cart-item__remove {
  font-size: 14px;
  color: var(--color-text-muted);
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
  transition: color 0.2s;
  line-height: 1;
}

.cart-item__remove:hover {
  color: #E24B4A;
}

/* Continue Shopping */
.cart__continue {
  padding-top: 24px;
}

/* Summary Box */
.cart__summary-box {
  background: var(--color-bg-light);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 28px 24px;
  margin-bottom: 20px;
}

.cart__summary-title {
  font-family: var(--font-heading);
  font-size: 18px;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--color-black);
  margin-bottom: 20px;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--color-border);
}

.cart__summary-rows {
  display: flex;
  flex-direction: column;
  gap: 14px;
  margin-bottom: 20px;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--color-border);
}

.cart__summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 14px;
  color: var(--color-text-muted);
}

/* Free Shipping Progress Bar */
.cart__free-shipping {
  background: var(--color-orange-light);
  border-radius: var(--radius-sm);
  padding: 12px 14px;
}

.cart__free-shipping-text {
  font-size: 12px;
  color: var(--color-orange-dark);
  margin: 0 0 8px;
}

.cart__free-shipping-text strong {
  color: var(--color-orange);
  font-weight: 700;
}

.cart__free-shipping-bar {
  background: #FBDBBF;
  border-radius: 10px;
  height: 6px;
  overflow: hidden;
}

.cart__free-shipping-fill {
  background: var(--color-orange);
  height: 100%;
  border-radius: 10px;
  transition: width 0.3s ease;
  min-width: 4px;
}

/* Total Row */
.cart__summary-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 18px;
  font-weight: 700;
  color: var(--color-black);
  margin-bottom: 20px;
}

/* Checkout Button */
.cart__checkout-btn {
  margin-bottom: 14px;
}

/* Payment Icons */
.cart__payment-icons {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  font-size: 12px;
  color: var(--color-text-muted);
  margin-bottom: 16px;
}

/* AI Nudge */
.cart__ai-nudge {
  display: block;
  font-size: 12px;
  font-weight: 500;
  color: var(--color-orange);
  text-align: center;
  padding: 10px;
  border: 1px dashed var(--color-orange);
  border-radius: var(--radius-sm);
  transition: background 0.2s;
}

.cart__ai-nudge:hover {
  background: var(--color-orange-light);
}

/* Trust Items in Cart */
.cart__trust {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.cart__trust-item {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 13px;
  color: var(--color-text-muted);
}

.cart__trust-item span {
  font-size: 18px;
}

.cart__trust-item p {
  margin: 0;
  font-size: 13px;
}

/* Empty Cart */
.cart__empty {
  text-align: center;
  padding: 80px 0;
}

.cart__empty-icon {
  font-size: 72px;
  margin-bottom: 24px;
}

.cart__empty h2 {
  font-family: var(--font-heading);
  font-size: 28px;
  color: var(--color-black);
  margin-bottom: 12px;
}

.cart__empty p {
  font-size: 15px;
  color: var(--color-text-muted);
  margin-bottom: 32px;
}

.cart__empty-btns {
  display: flex;
  gap: 16px;
  justify-content: center;
  flex-wrap: wrap;
}

/* Mobile */
@media (max-width: 768px) {
  .cart__inner {
    grid-template-columns: 1fr;
  }

  .cart__table-header {
    display: none;
  }

  .cart-item {
    grid-template-columns: 80px 1fr;
    grid-template-rows: auto auto auto;
  }

  .cart-item__img {
    grid-row: 1 / 3;
    grid-column: 1;
    align-items: flex-start;
  }

  .cart-item__info {
    grid-column: 2;
    grid-row: 1;
  }

  .cart-item__remove-mobile {
    display: block;
  }

  .cart-item__price {
    display: none;
  }

  .cart-item__qty {
    grid-column: 2;
    grid-row: 2;
  }

  .cart-item__total {
    grid-column: 2;
    grid-row: 3;
    font-size: 14px;
  }

  .cart-item__remove {
    display: none;
  }
}
</style>

<!-- Cart JavaScript -->
<script>
  // Update quantity via Shopify Cart API
  function updateQty(key, newQty) {
    if (newQty < 0) return;

    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: key, quantity: newQty })
    })
    .then(res => res.json())
    .then(cart => {
      // Reload page to reflect changes
      window.location.reload();
    });
  }

  // Remove item from cart
  function removeItem(key) {
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: key, quantity: 0 })
    })
    .then(res => res.json())
    .then(() => {
      window.location.reload();
    });
  }
</script>